# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# OLLAMA_API_KEY: Bearer token for Ollama Cloud (https://ollama.com), used automatically
# for the seeded "Ollama Cloud Gateway" node. Get a key at https://ollama.com/settings/keys.
# This is a placeholder; put your real key in a local, gitignored .env file.
OLLAMA_API_KEY=MY_OLLAMA_API_KEY
